# Application
PORT=4000
NODE_ENV=development
WEB_URL=http://localhost:3000

# JWT
JWT_SECRET=change-me-in-production

# Database (when ready to connect PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/home_solutions

# Peach Payments
# Get credentials from https://developer.peachpayments.com
PEACH_MODE=test
PEACH_ENTITY_ID=your-entity-id-here
PEACH_ACCESS_TOKEN=your-access-token-here

# Firebase (push notifications)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY=your-private-key

# Africa's Talking SMS
AT_API_KEY=your-at-api-key
AT_USERNAME=sandbox
