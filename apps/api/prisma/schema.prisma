generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  phone               String   @unique
  email               String?  @unique
  passwordHash        String
  role                String   @default("client")
  firstName           String?
  lastName            String?
  // Provider-only fields
  companyName         String?
  companyRegistration String?
  vatNumber           String?
  serviceArea         String?
  pushToken           String?
  createdAt           DateTime @default(now())
}

model Provider {
  id              String    @id @default(uuid())
  name            String
  phone           String    @unique
  email           String?
  skills          String[]
  kycStatus       String    @default("pending")
  status          String    @default("pending_kyc")
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  jobCount        Int       @default(0)
  earningsBalance Float     @default(0)
  monFri          Boolean   @default(true)
  saturday        Boolean   @default(false)
  sunday          Boolean   @default(false)
  emergency       Boolean   @default(false)
  lat             Float?
  lng             Float?
  serviceAreas    String[]
  hireInventory   Json?
  createdAt       DateTime  @default(now())
  bookings        Booking[]
}

model HardwareStore {
  id        String          @id @default(uuid())
  name      String
  email     String          @unique
  phone     String
  address   String
  areas     String[]
  isActive  Boolean         @default(true)
  products  Product[]
  orders    MaterialOrder[]
  createdAt DateTime        @default(now())
}

model Product {
  id          String              @id @default(uuid())
  storeId     String
  store       HardwareStore       @relation(fields: [storeId], references: [id])
  name        String
  category    String
  description String?
  unit        String              @default("each")
  price       Float
  inStock     Boolean             @default(true)
  sku         String?
  createdAt   DateTime            @default(now())
  orderItems  MaterialOrderItem[]
}

model MaterialOrder {
  id          String              @id @default(uuid())
  bookingId   String
  providerId  String
  storeId     String
  store       HardwareStore       @relation(fields: [storeId], references: [id])
  status      String              @default("pending")
  totalAmount Float               @default(0)
  notes       String?
  items       MaterialOrderItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model MaterialOrderItem {
  id        String        @id @default(uuid())
  orderId   String
  order     MaterialOrder @relation(fields: [orderId], references: [id])
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  quantity  Float
  unitPrice Float
  total     Float
}

model KycDocument {
  id         String   @id @default(uuid())
  providerId String
  type       String   // 'id' | 'company_reg' | 'bank_letter'
  fileName   String
  fileUrl    String
  status     String   @default("pending") // pending | approved | rejected
  createdAt  DateTime @default(now())

  @@unique([providerId, type])
}

model Message {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  senderId    String
  senderRole  String   // 'client' | 'provider' | 'admin'
  senderName  String
  text        String   @default("")
  attachments Json?    // [{ url, type: 'image'|'file', fileName }]
  createdAt   DateTime @default(now())
}

model Subscription {
  id           String   @id @default(uuid())
  userId       String
  userRole     String   // 'client' | 'provider'
  planId       String
  status       String   @default("active") // active | cancelled | expired
  peachTokenId String?
  startsAt     DateTime @default(now())
  expiresAt    DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, userRole])
}

model Review {
  id         String   @id @default(uuid())
  providerId String
  clientId   String
  bookingId  String?
  stars      Int
  tags       String[]
  comment    String?
  createdAt  DateTime @default(now())

  @@index([providerId])
}

model BankAccount {
  id            String   @id @default(uuid())
  userId        String   @unique
  accountHolder String
  bankName      String
  accountNumber String
  branchCode    String
  accountType   String   @default("cheque")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  label     String
  address   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   // new_job | provider_assigned | job_complete | chat_message | payment
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Booking {
  id               String    @id @default(uuid())
  clientId         String
  providerId       String?
  provider         Provider? @relation(fields: [providerId], references: [id])
  serviceType      String
  status           String    @default("pending")
  location         String
  address          String
  quotedAmount     Float
  finalAmount      Float?
  paymentMethod    String    @default("card")
  paymentHeld      Boolean   @default(false)
  paymentReleased  Boolean   @default(false)
  transactionId    String?
  serviceDetails   Json?
  images           String[]
  warrantyExpiresAt DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  messages         Message[]
}
