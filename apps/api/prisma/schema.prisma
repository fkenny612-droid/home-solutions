generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  phone               String   @unique
  email               String?  @unique
  passwordHash        String
  role                String   @default("client")
  firstName           String?
  lastName            String?
  // Provider-only fields
  companyName         String?
  companyRegistration String?
  vatNumber           String?
  serviceArea         String?
  pushToken           String?
  createdAt           DateTime @default(now())
}

model Provider {
  id              String    @id @default(uuid())
  name            String
  phone           String    @unique
  email           String?
  skills          String[]
  kycStatus       String    @default("pending")
  status          String    @default("pending_kyc")
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  jobCount        Int       @default(0)
  earningsBalance Float     @default(0)
  monFri          Boolean   @default(true)
  saturday        Boolean   @default(false)
  sunday          Boolean   @default(false)
  emergency       Boolean   @default(false)
  lat             Float?
  lng             Float?
  createdAt       DateTime  @default(now())
  bookings        Booking[]
}

model HardwareStore {
  id        String          @id @default(uuid())
  name      String
  email     String          @unique
  phone     String
  address   String
  areas     String[]
  isActive  Boolean         @default(true)
  products  Product[]
  orders    MaterialOrder[]
  createdAt DateTime        @default(now())
}

model Product {
  id          String              @id @default(uuid())
  storeId     String
  store       HardwareStore       @relation(fields: [storeId], references: [id])
  name        String
  category    String
  description String?
  unit        String              @default("each")
  price       Float
  inStock     Boolean             @default(true)
  sku         String?
  createdAt   DateTime            @default(now())
  orderItems  MaterialOrderItem[]
}

model MaterialOrder {
  id          String              @id @default(uuid())
  bookingId   String
  providerId  String
  storeId     String
  store       HardwareStore       @relation(fields: [storeId], references: [id])
  status      String              @default("pending")
  totalAmount Float               @default(0)
  notes       String?
  items       MaterialOrderItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model MaterialOrderItem {
  id        String        @id @default(uuid())
  orderId   String
  order     MaterialOrder @relation(fields: [orderId], references: [id])
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  quantity  Float
  unitPrice Float
  total     Float
}

model KycDocument {
  id         String   @id @default(uuid())
  providerId String
  type       String   // 'id' | 'company_reg' | 'bank_letter'
  fileName   String
  fileUrl    String
  status     String   @default("pending") // pending | approved | rejected
  createdAt  DateTime @default(now())

  @@unique([providerId, type])
}

model Booking {
  id               String    @id @default(uuid())
  clientId         String
  providerId       String?
  provider         Provider? @relation(fields: [providerId], references: [id])
  serviceType      String
  status           String    @default("pending")
  location         String
  address          String
  quotedAmount     Float
  finalAmount      Float?
  paymentMethod    String    @default("card")
  paymentHeld      Boolean   @default(false)
  paymentReleased  Boolean   @default(false)
  transactionId    String?
  serviceDetails   Json?
  images           String[]
  warrantyExpiresAt DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
