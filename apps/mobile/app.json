{
  "expo": {
    "name": "Home Solutions",
    "slug": "home-solutions",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "homesolutions",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.za.homesolutions.app"
    },
    "android": {
      "package": "co.za.homesolutions.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F1923",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
